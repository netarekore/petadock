{
  "name": "petadock",
  "version": "1.0.1",
  "description": "PetaDock - Custom Clipboard Manager",
  "author": "netarekore",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.9",
    "koffi": "^2.8.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.netarekore.petadock",
    "productName": "PetaDock",
    "files": [
      "src/**/*",
      "node_modules/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "netarekore",
        "repo": "petadock",
        "releaseType": "release"
      }
    ],
    "win": {
      "icon": "src/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": "src/icon.ico",
      "uninstallerIcon": "src/icon.ico",
      "shortcutName": "PetaDock",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    }
  }
}